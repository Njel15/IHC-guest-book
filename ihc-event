<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IHC & Maldives Guest Book</title>
    <link href="https://fonts.cdnfonts.com/css/glacial-indifference" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <style>
        :root {
            --bg-blue-full: #5876D6; 
            --apple-blue: #007AFF;
        }

        body {
            font-family: 'Glacial Indifference', sans-serif;
            background-color: #f5f5f7;
            margin: 0; display: flex; justify-content: center; align-items: center; min-height: 100vh;
        }

        .card {
            width: 100%; max-width: 420px;
            background-color: var(--bg-blue-full);
            border-radius: 40px; padding: 40px 30px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.15);
            text-align: center; color: white;
            box-sizing: border-box;
        }

        /* LOGO HEADER FIX */
        .logo-header { 
            display: flex; 
            justify-content: center; 
            align-items: center;
            gap: 3px; 
            margin-bottom: 3px; 
        }
        
        .logo-box { 
            width: 200px; 
            height: 160px;
            display: flex; 
            justify-content: center; 
            align-items: center;
        }

        .logo-box img { 
            max-width: 100%; 
            max-height: 100%; 
            object-fit: contain; 
        }

        h2 { font-weight: 800; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 35px; font-size: 32px; }

        /* FORM ALIGNMENT FIX */
        .field-container { display: flex; flex-direction: column; gap: 20px; }
        
        .row { 
            display: flex; 
            flex-direction: row; 
            align-items: center; 
            justify-content: space-between;
            width: 100%;
        }

        label { 
            width: 100px; /* Lebar tetap agar teks di kiri rata */
            font-size: 14px; 
            font-weight: 800; 
            text-transform: uppercase; 
            text-align: left;
            color: white;
        }
        
        input {
            flex: 1; /* Mengambil sisa ruang */
            padding: 16px 20px; 
            border: none; 
            border-radius: 15px;
            font-size: 16px; 
            font-family: 'Glacial Indifference', sans-serif;
            box-sizing: border-box; 
            color: #1d1d1f; 
            background: #fff;
        }

        /* Row khusus WA agar tombol Verifikasi pas */
        .wa-input-wrapper {
            flex: 1;
            display: flex;
            gap: 10px;
        }

        .btn-verify {
            background: white; color: var(--apple-blue); border: none;
            padding: 0 15px; border-radius: 12px; font-weight: 800; cursor: pointer;
            text-transform: uppercase; font-size: 12px;
            height: 50px; /* Samakan dengan tinggi input */
        }

        /* BUTTONS */
        .btn-action {
            width: 100%; padding: 18px; background: #000; color: white;
            border: none; border-radius: 16px; font-size: 16px; font-weight: 700;
            text-transform: uppercase; cursor: pointer; margin-top: 10px;
        }

        .agreement { display: flex; align-items: center; gap: 12px; margin: 25px 0; font-weight: 700; font-size: 14px; justify-content: center; }
        
        /* GIFT BOX */
        .gift-container { display: flex; justify-content: center; gap: 15px; margin: 30px 0; }
        .gift-box {
            font-size: 40px; cursor: pointer; background: rgba(255,255,255,0.2);
            width: 90px; height: 90px; display: flex; align-items: center; justify-content: center;
            border-radius: 20px; border: 2px dashed rgba(255,255,255,0.4);
        }
        .shuffle { animation: shake 0.5s infinite; }
        @keyframes shake {
            0% { transform: rotate(0deg); }
            25% { transform: rotate(5deg); }
            75% { transform: rotate(-5deg); }
            100% { transform: rotate(0deg); }
        }

        .hidden { display: none; }
        #result-text { font-size: 22px; font-weight: 800; margin-top: 20px; }
    </style>
</head>
<body>

<div class="card">
    <div class="logo-header">
        <div class="logo-box">
            <img src="https://lh3.googleusercontent.com/d/1njp0_DvILEDf0aFz3srVPoo6NRTakSIi" alt="Logo IHC">
        </div>
        <div class="logo-box">
            <img src="https://lh3.googleusercontent.com/d/1RiN521tN69IN19lLVrqfDceqnKfEncux" alt="Logo Maldives">
        </div>
    </div>

    <div id="step-1">
        <h2>Guest Book</h2>
        <div class="field-container">
            <div class="row">
                <label>Nama</label>
                <input type="text" id="nama" placeholder="Full Name">
            </div>
            <div class="row">
                <label>Instagram</label>
                <input type="text" id="ig" placeholder="@username">
            </div>
            <div class="row">
                <label>Whatsapp</label>
                <div class="wa-input-wrapper">
                    <input type="tel" id="hp" placeholder="081xxx" style="width: 60%;">
                    <button class="btn-verify" onclick="submitStep1()">Verifikasi</button>
                </div>
            </div>
        </div>
    </div>

    <div id="step-2" class="hidden">
        <h2>Follow Us</h2>
        <button class="btn-action" onclick="window.open('https://instagram.com/indo_collections')">Follow @indo_collections</button>
        <button class="btn-action" onclick="window.open('https://instagram.com/maldives.legend')" style="background:#333">Follow @maldives.legend</button>
        <label class="agreement">
            <input type="checkbox" id="check-follow" onchange="document.getElementById('btn-lanjut').disabled = !this.checked">
            <span>SAYA SUDAH FOLLOW KEDUANYA</span>
        </label>
        <button class="btn-action" id="btn-lanjut" style="background:#fff; color:var(--apple-blue)" onclick="showGifts()" disabled>LANJUT AMBIL KADO</button>
    </div>

    <div id="step-3" class="hidden">
        <h2>Lucky Draw</h2>
        <div class="gift-container">
            <div class="gift-box" onclick="pickGift(0)">🎁</div>
            <div class="gift-box" onclick="pickGift(1)">🎁</div>
            <div class="gift-box" onclick="pickGift(2)">🎁</div>
        </div>
        <div id="result-text"></div>
    </div>
</div>

<script>
    const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwUg_yLBBeqf0a9b0YTxKxZW4KFAr51OjCUz4XVXelN4yvd4iWwePwypb6VYZEFG-7S/exec';
    const WA_NUMBER = '62818500015';
    let isPicked = false;

    function submitStep1() {
        const n = document.getElementById('nama').value;
        const i = document.getElementById('ig').value;
        const h = document.getElementById('hp').value;
        if(!n || !h) return alert("Isi data dulu!");

        fetch(SCRIPT_URL, { method: 'POST', mode: 'no-cors', body: new URLSearchParams({nama: n, instagram: i, nohp: h}) });
        window.open(`https://wa.me/${WA_NUMBER}?text=${encodeURIComponent('Halo IHC, saya '+n+' (IG: '+i+') sudah isi buku tamu.')}`, '_blank');

        document.getElementById('step-1').classList.add('hidden');
        document.getElementById('step-2').classList.remove('hidden');
    }

    function showGifts() {
        document.getElementById('step-2').classList.add('hidden');
        document.getElementById('step-3').classList.remove('hidden');
        const boxes = document.querySelectorAll('.gift-box');
        boxes.forEach(box => box.classList.add('shuffle'));
        setTimeout(() => { boxes.forEach(box => box.classList.remove('shuffle')); }, 1500);
    }

    function pickGift(idx) {
        if(isPicked) return;
        isPicked = true;
        const boxes = document.querySelectorAll('.gift-box');
        let r = Math.random() * 100;
        let hadiah = r < 50 ? "KIPAS" : (r < 90 ? "KEYCHAIN" : "MUG");

        boxes[idx].innerHTML = `<span style="font-size:14px; color:#000;">${hadiah}</span>`;
        boxes[idx].style.background = "#fff";
        boxes.forEach((b, i) => { if(i !== idx) b.style.opacity = "0.3"; });

        confetti({ particleCount: 150, spread: 70, origin: { y: 0.6 } });
        document.getElementById('result-text').innerText = "SELAMAT! DAPAT: " + hadiah;

        fetch(SCRIPT_URL, { method: 'POST', mode: 'no-cors', body: new URLSearchParams({instagram: document.getElementById('ig').value, hadiah: hadiah}) });
    }
</script>
</body>
</html>
